# Vendored repos (cloned for reference, not committed)
VCC/
apm/

# Generated output — per-technology skills, guardians, memory
.claude/agent-memory/
.claude/guardian-memory/
.claude/skill-sources/
.claude/skill-packages/

# Generated guardians (per-technology, built by guardian-forge)
.claude/agents/*-guardian.md

# Generated skills (per-technology, built by agent-forge)
# Framework skills (apm-*) are tracked — they're infrastructure, not per-tech output
.claude/skills/*
!.claude/skills/apm-packaging/
!.claude/skills/apm-cli/
!.claude/skills/apm-distribution/

# Tests (internal framework validation)
tests/

# APM runtime (generated by apm install, not the repo's own apm.yml/.apm/)
apm_modules/
apm.lock.yaml

# Internal docs/notes
docs/

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
